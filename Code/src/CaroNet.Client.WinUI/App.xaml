<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CaroNet.Client.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CaroNet.Client.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Fallback brush theo theme để tránh lệch màu khi runtime thiếu Fluent resource key. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#DADCE0"/>
                    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#F4F6F8"/>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#0F6CBD"/>
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#1A1A1A"/>
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#5F6368"/>
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#8A8F98"/>
                    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="#B3261E"/>
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#C7CBD1"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#262626"/>
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#3A3A3A"/>
                    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#303030"/>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#4EA3FF"/>
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F2F4F8"/>
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#C7CDD6"/>
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#858C96"/>
                    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="#FF6B6B"/>
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#4A4A4A"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#262626"/>
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#3A3A3A"/>
                    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#303030"/>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#4EA3FF"/>
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#F2F4F8"/>
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#C7CDD6"/>
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#858C96"/>
                    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="#FF6B6B"/>
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#4A4A4A"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
