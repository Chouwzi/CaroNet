<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaroNet.Client.WinUI.Views.MainMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="32">
        <StackPanel Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18">

            <TextBlock Text="CaroNet"
                       HorizontalAlignment="Center"
                       FontSize="56"
                       FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <TextBox x:Name="PlayerNameTextBox"
                     Header="Tên người chơi"
                     PlaceholderText="Nhập tên người chơi"
                     Text="{Binding PlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Height="70"
                     FontSize="17"
                     CornerRadius="12"/>

            <Button x:Name="ConnectButton"
                    Height="52"
                    HorizontalAlignment="Stretch"
                    CornerRadius="12"
                    Click="ConnectButton_Click">
                <TextBlock Text="Connect"
                           FontSize="17"
                           FontWeight="SemiBold"/>
            </Button>

            <TextBox x:Name="RoomIdTextBox"
                     Header="Room ID"
                     PlaceholderText="ROOM-001"
                     Text="{Binding RoomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Height="70"
                     FontSize="17"
                     CornerRadius="12"/>

            <Button x:Name="CreateRoomButton"
                    Height="52"
                    HorizontalAlignment="Stretch"
                    CornerRadius="12"
                    Click="CreateRoomButton_Click">
                <TextBlock Text="Tạo phòng"
                           FontSize="17"
                           FontWeight="SemiBold"/>
            </Button>

            <Button x:Name="JoinRoomButton"
                    Height="52"
                    HorizontalAlignment="Stretch"
                    CornerRadius="12"
                    Click="JoinRoomButton_Click">
                <TextBlock Text="Vào phòng"
                           FontSize="17"
                           FontWeight="SemiBold"/>
            </Button>

            <TextBlock x:Name="ConnectionStatusText"
                       Text="{Binding ConnectionStatus}"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
