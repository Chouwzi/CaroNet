<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaroNet.Client.WinUI.Views.MainMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="32">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Width="600"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Spacing="18">

                <TextBlock Text="CaroNet"
                           HorizontalAlignment="Center"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <TextBox x:Name="PlayerNameTextBox"
                         Header="Tên người chơi"
                         PlaceholderText="Nhập tên người chơi"
                         Text="{Binding PlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="70"
                         FontSize="17"
                         CornerRadius="12"/>

                <TextBox x:Name="ServerHostTextBox"
                         Header="Server Host"
                         PlaceholderText="127.0.0.1"
                         Text="{Binding ServerHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="70"
                         FontSize="17"
                         CornerRadius="12"/>

                <TextBox x:Name="ServerPortTextBox"
                         Header="Server Port"
                         PlaceholderText="5000"
                         Text="{Binding ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="70"
                         FontSize="17"
                         CornerRadius="12"/>

                <Button x:Name="ConnectButton"
                        Height="52"
                        HorizontalAlignment="Stretch"
                        CornerRadius="12"
                        Click="ConnectButton_Click">
                    <TextBlock Text="Chơi nhanh"
                               FontSize="17"
                               FontWeight="SemiBold"/>
                </Button>

                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="JoinRoomButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            CornerRadius="12"
                            Click="JoinRoomButton_Click"
                            Grid.Column="0">
                        <TextBlock Text="Vào phòng"
                                   FontSize="17"
                                   FontWeight="SemiBold"/>
                    </Button>

                    <TextBox x:Name="RoomIdTextBox"
                             PlaceholderText="Nhập mã phòng"
                             Text="{Binding RoomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="52"
                             FontSize="17"
                             CornerRadius="12"
                             Grid.Column="1"/>
                </Grid>

                <Button x:Name="CreateRoomButton"
                        Height="52"
                        HorizontalAlignment="Stretch"
                        CornerRadius="12"
                        Click="CreateRoomButton_Click">
                    <TextBlock Text="Tạo phòng"
                               FontSize="17"
                               FontWeight="SemiBold"/>
                </Button>

                <Button x:Name="HistoryButton"
                        Height="52"
                        HorizontalAlignment="Stretch"
                        CornerRadius="12"
                        Click="HistoryButton_Click">
                    <TextBlock Text="Lịch sử trận đấu"
                               FontSize="17"
                               FontWeight="SemiBold"/>
                </Button>

                <Button x:Name="BestRecordButton"
                        Height="52"
                        HorizontalAlignment="Stretch"
                        CornerRadius="12"
                        Click="BestRecordButton_Click">
                    <TextBlock Text="Best Record (Top 10)"
                               FontSize="17"
                               FontWeight="SemiBold"/>
                </Button>

                <ListView x:Name="BestRecordList"
                          Visibility="Collapsed"
                          ItemsSource="{Binding BestRecords}"
                          SelectionMode="None"
                          MaxHeight="300">

                    <ListView.ItemTemplate>
                        <DataTemplate>

                            <Border Margin="0,4"
                                    Padding="12"
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    CornerRadius="10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Rank}"
                                               FontWeight="Bold"
                                               FontSize="18"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlayerName}"
                                               FontSize="18"/>

                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               FontSize="18">
                                        <Run Text="{Binding Wins}"/>
                                        <Run Text=" Wins"/>
                                    </TextBlock>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

                <TextBlock x:Name="ConnectionStatusText"
                           Text="{Binding ConnectionStatus}"
                           HorizontalAlignment="Center"
                           FontSize="17"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Page>