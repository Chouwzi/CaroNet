<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaroNet.Client.WinUI.Views.MainMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CaroNet.Client.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="32">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Width="620"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Spacing="18">

                <TextBlock Text="CaroNet"
                           HorizontalAlignment="Center"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <Border Padding="18"
                        CornerRadius="8"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Tài khoản"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="UsernameTextBox"
                                 Header="Tên đăng nhập"
                                 PlaceholderText="Ví dụ: annie123"
                                 Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="64"
                                 Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <PasswordBox x:Name="PasswordInput"
                                     Header="Mật khẩu"
                                     PlaceholderText="Nhập mật khẩu"
                                     PasswordChanged="PasswordInput_PasswordChanged"
                                     Height="64"
                                     Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <Button x:Name="LoginButton"
                                Height="48"
                                HorizontalAlignment="Stretch"
                                Content="Đăng nhập"
                                Click="LoginButton_Click"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <HyperlinkButton x:Name="CreateAccountLink"
                                         HorizontalAlignment="Center"
                                         Content="Chưa có tài khoản? Tạo tài khoản"
                                         Click="CreateAccountLink_Click"
                                         Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <TextBlock Text="{Binding GreetingText}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Text="{Binding AuthStatus}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        CornerRadius="8"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Kết nối server"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ServerHostTextBox"
                                     Grid.Column="0"
                                     Header="Server Host"
                                     PlaceholderText="127.0.0.1"
                                     Text="{Binding ServerHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="64"/>

                            <TextBox x:Name="ServerPortTextBox"
                                     Grid.Column="1"
                                     Header="Server Port"
                                     PlaceholderText="5000"
                                     Text="{Binding ServerPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="64"/>
                        </Grid>

                        <TextBlock Text="{Binding ConnectionStatus}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Spacing="12"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button x:Name="QuickMatchButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            Content="Chơi nhanh"
                            Click="QuickMatchButton_Click"/>

                    <Button x:Name="JoinRoomButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            Content="Vào phòng"
                            Click="JoinRoomButton_Click"/>

                    <Button x:Name="CreateRoomButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            Content="Tạo phòng"
                            Click="CreateRoomButton_Click"/>

                    <Button x:Name="HistoryButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            Content="Lịch sử trận đấu"
                            Click="HistoryButton_Click"/>

                    <Button x:Name="BestRecordButton"
                            Height="52"
                            HorizontalAlignment="Stretch"
                            Content="Ranking (Top 10)"
                            Click="BestRecordButton_Click"/>
                </StackPanel>

                <ListView x:Name="BestRecordList"
                          Visibility="Collapsed"
                          ItemsSource="{Binding BestRecords}"
                          SelectionMode="None"
                          MaxHeight="300">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4"
                                    Padding="12"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Rank}"
                                               FontWeight="Bold"
                                               FontSize="18"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlayerName}"
                                               FontSize="18"/>

                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               FontSize="18">
                                        <Run Text="{Binding Wins}"/>
                                        <Run Text=" Wins"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
