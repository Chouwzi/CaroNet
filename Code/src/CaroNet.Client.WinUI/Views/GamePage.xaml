<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaroNet.Client.WinUI.Views.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CaroNet.Client.WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="BoardCellButtonStyle"
               TargetType="Button">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="10">
        <Grid RowDefinitions="92,*"
              ColumnDefinitions="*,360"
              RowSpacing="10"
              ColumnSpacing="10">

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,0">
                <Grid ColumnDefinitions="*,160,*"
                      ColumnSpacing="16">

                    <Border Grid.Column="0"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Opacity="{Binding MyHeaderOpacity}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="BẠN"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Text="{Binding PlayerName}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PlayerSymbol}"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding MyTurnLabel}"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                        <TextBlock Text="{Binding ScoreText}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RoomId}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="2"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Opacity="{Binding OpponentHeaderOpacity}">
                        <StackPanel HorizontalAlignment="Right"
                                    Spacing="2">
                            <TextBlock Text="ĐỐI THỦ"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8">
                                <TextBlock Text="{Binding OpponentSymbol}"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding OpponentName}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="20"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding OpponentTurnLabel}"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Game Area -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="18">

                    <!-- Turn Banner -->
                    <Border x:Name="TurnBanner"
                            Grid.Row="0"
                            Background="#E8F5E9"
                            CornerRadius="10"
                            Padding="16,12"
                            BorderThickness="1"
                            BorderBrush="#A5D6A7">
                        <TextBlock Text="{Binding TurnMessage}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="#1B5E20"/>
                    </Border>

                    <!-- Board -->
                    <Viewbox Grid.Row="1"
                             Stretch="Uniform">
                        <Border Width="620"
                                Height="620"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="10">
                            <Grid x:Name="BoardGrid"
                                  Background="{ThemeResource LayerFillColorDefaultBrush}"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- Right Sidebar -->
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  RowDefinitions="220,*,76"
                  RowSpacing="16">

                <!-- Match Info -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Match Info"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       FontSize="21"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="10">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Text="Your symbol"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PlayerSymbol}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Text="Room"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RoomId}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>
                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Text="Current turn"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentTurnSymbol}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="22"
        Padding="20">

                    <Grid RowDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Chat"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       FontSize="21"
                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ConnectionStatus}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock x:Name="EmptyStateTextBlock"
                   Grid.Row="1"
                   Text="Chưa có tin nhắn"
                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                   FontSize="14"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                        <ListView x:Name="ChatListView"
                  Grid.Row="1"
                  ItemsSource="{Binding ChatMessages}"
                  SelectionMode="None"
                  Background="Transparent"
                  BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3"
                                          ColumnSpacing="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="["
                                                   Grid.Column="0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="{Binding SenderName}"
                                                   Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="]: "
                                                   Grid.Column="2"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="{Binding Message}"
                                                   Grid.Column="3"
                                                   TextWrapping="WrapWholeWords"
                                                   FontSize="14"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Grid.Row="2"
                   Text="{Binding ServerError}"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="22"
        Padding="12">

                    <Grid ColumnDefinitions="*,52"
          ColumnSpacing="10">

                        <TextBox x:Name="ChatInputTextBox"
                 Grid.Column="0"
                 PlaceholderText="Nhập chat..."
                 Text="{Binding ChatInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsChatInputEnabled}"
                 FontSize="15"
                 BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                 BorderThickness="1"
                 CornerRadius="14"
                 Padding="14,8"/>

                        <Button x:Name="SendChatButton"
                Grid.Column="1"
                Content="➜"
                Click="SendChatButton_Click"
                IsEnabled="{Binding IsSendButtonEnabled}"
                MinWidth="44"
                MinHeight="44"
                FontSize="20"
                FontWeight="SemiBold"
                CornerRadius="14"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
