<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaroNet.Client.WinUI.Views.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CaroNet.Client.WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="BoardCellButtonStyle"
               TargetType="Button">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="10">

        <Grid RowDefinitions="92,*"
              ColumnDefinitions="*,360"
              RowSpacing="10"
              ColumnSpacing="10">

            <!-- ================= HEADER BLOCK ================= -->
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24,0">

                <Grid ColumnDefinitions="*,180,*">

                    <!-- Player A -->
                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                Spacing="2">

                        <TextBlock Text="PLAYER"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding PlayerName}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Score -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="18">

                        <TextBlock Text="{Binding PlayerSymbol}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"/>

                        <TextBlock Text="/"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding CurrentTurnSymbol}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Player B -->
                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Spacing="2">

                        <TextBlock Text="ROOM"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>

                        <TextBlock Text="{Binding RoomId}"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Server authoritative"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ================= BOARD BLOCK ================= -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24">

                <Grid RowDefinitions="*"
                      RowSpacing="18">

                    <!-- <StackPanel Grid.Row="0"
                                Spacing="4">

                        <TextBlock Text="Caro Board"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel> -->

                    <Viewbox Stretch="Uniform">

                        <Border Width="620"
                                Height="620"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="10">

                            <Grid x:Name="BoardGrid"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"/>

                        </Border>

                    </Viewbox>

                </Grid>
            </Border>

            <!-- ================= RIGHT SIDE ================= -->
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="16">

                <!-- ========== INFO BLOCK ========== -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="20">

                    <StackPanel Spacing="16">

                        <StackPanel Spacing="4">
                            <TextBlock Text="Match Info"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       FontSize="21"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="10">

                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto">

                                <TextBlock Text="Your symbol"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding PlayerSymbol}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,Auto">

                                <TextBlock Text="Room"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding RoomId}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="*,Auto">

                                <TextBlock Text="Current turn"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="14"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentTurnSymbol}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Grid>

                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== STATUS BLOCK ========== -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="20">

                    <StackPanel Spacing="12">
                        <TextBlock Text="Server Status"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   FontSize="21"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding ServerError}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>
    </Grid>
</Page>
